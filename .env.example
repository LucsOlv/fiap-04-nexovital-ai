# NexoVital AI MVP - variáveis de ambiente
# Copie para .env e ajuste. NÃO coloque segredos reais aqui.

# Backend
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
APP_ENV=local

# Azure Speech to Text
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure AI Language
AZURE_LANGUAGE_KEY=
AZURE_LANGUAGE_ENDPOINT=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=60.0
OPENROUTER_MAX_RETRIES=3

# Alert webhook (opcional)
WEBHOOK_ALERT_URL=

# Media limits
VIDEO_MAX_BYTES=26214400
VIDEO_MAX_DURATION_SECONDS=30.0
AUDIO_MAX_BYTES=10485760
AUDIO_MAX_DURATION_SECONDS=120.0
CSV_MAX_BYTES=1048576
CSV_MAX_ROWS=500

# Frontend
VITE_API_BASE_URL=http://localhost:8000
